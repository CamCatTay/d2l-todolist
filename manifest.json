{
  "manifest_version": 3,
  "name": "D2L Course Scraping Extension",
  "version": "1.0.0",
  "description": "An extension to scrape course data from D2L.",
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.brightspace.com/*"
  ],
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": "images/notebook.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  }
}