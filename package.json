{
  "name": "spark-for-brightspace",
  "version": "1.2.1",
  "description": "A productivity extension for Brightspace.",
  "scripts": {
    "test": "echo 'Tests disabled — pending TypeScript migration'",
    "build:content": "vite build --config vite.content.config.js",
    "build:background": "vite build --config vite.background.config.js",
    "build": "npm run build:content && npm run build:background",
    "package": "npm run build && node ./scripts/package-extension.js",
    "version": "node ./scripts/sync-version.js && git add manifest.json"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/chrome": "^0.1.40",
    "adm-zip": "^0.5.17",
    "babel-jest": "^30.3.0",
    "jest": "^29.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "_jest_disabled": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "_comment": "handles absolute imports, relative paths being used I think so may not be needed",
    "moduleNameMapper": {
      "^/src/(.*)$": "<rootDir>/src/$1"
    }
  }
}
